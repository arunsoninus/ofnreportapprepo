<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:M="sap.m">
	<TableSelectDialog noDataText="No Data Found" title="Select Staff" search=".handleSearchHRPStaff"
		confirm=".handleConfirmStaff($event, 'HRP')" contentHeight="auto" contentWidth="40%" cancel=".handleCloseStaff" multiSelect="true"
		growingThreshold="1000" items="{ path : 'AppModel>/hrpStaffList' }">
		<ColumnListItem vAlign="Middle">
			<cells>
				<Text text="{AppModel>FULL_NM}"/>
			</cells>
		</ColumnListItem>
		<columns>
			<Column minScreenWidth="Desktop" demandPopin="true">
				<header>
					<Label text="Full Name" design="Bold"/>
				</header>
			</Column>
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>
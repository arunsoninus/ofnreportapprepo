<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<TableSelectDialog noDataText="No Data Found" title="Select ULU" search=".handleSearch($event, 'ULU_C', 'ULU_T')"
		liveChange=".handleSearch($event, 'ULU_C', 'ULU_T')" confirm=".handleConfirmUlu" contentHeight="auto" contentWidth="40%"
		cancel=".handleCloseUluFdlu" multiSelect="true" growingThreshold="200"
		items="{ path : 'AppModel>/lkSelection/UluList', sorter : { path : 'ULU_T', descending : false } }">
		<ColumnListItem vAlign="Middle"  selected="{AppModel>Selected}">
			<cells>
				<ObjectIdentifier title="{AppModel>ULU_T}" text="{AppModel>ULU_C}" titleActive="false"/>
			</cells>
		</ColumnListItem>
		<columns>
			<Column minScreenWidth="Desktop" demandPopin="true">
				<header>
					<Text text="Select All"/>
				</header>
			</Column>
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>
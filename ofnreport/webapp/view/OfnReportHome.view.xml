<mvc:View controllerName="nus.edu.sg.ofnreport.controller.OfnReportHome" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core" displayBlock="true"
	xmlns="sap.m">
	<App id="app">
		<Page id="page" showHeader="false" title="{i18n>title}">
			<subHeader>
				<OverflowToolbar>
					<Button icon="sap-icon://grid" press="onNavDashBoard" type="Transparent" tooltip="Dashboard"/>
					  
				</OverflowToolbar>
			</subHeader>
			<content>
				<core:Fragment fragmentName="nus.edu.sg.ofnreport.view.subview.OFNReportFilter" type="XML"/>
				<core:Fragment fragmentName="nus.edu.sg.ofnreport.view.subview.OFNReportTable" type="XML"/></content>
		</Page>
	</App>
</mvc:View>